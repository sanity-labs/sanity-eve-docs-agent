# Copy to .env.local (eve loads it from the project root).

# ── Sanity Content Agent (the read + write content brain) ────────────────────
SANITY_ORG_ID=                  # your organization ID (Sanity project settings)
SANITY_API_WRITE_TOKEN=         # project token, Editor role or above (writes drafts)
SANITY_CONTENT_AGENT_APP_KEY=   # optional; only needed if multiple Studios share the dataset

# ── Sanity project (feedback query + Studio links) ───────────────────────────
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
# The "Review release" button URL is derived from your deployed Studio app
# (via SANITY_CONTENT_AGENT_APP_KEY) — no separate Studio URL needed.

# ── Slack (the agent posts review-ready notices here) ────────────────────────
SLACK_WEBHOOK_URL=              # a Slack incoming webhook URL

# ── eve orchestrator model (or run `npx eve link`) ───────────────────────────
AI_GATEWAY_API_KEY=

# ── Trigger auth: shared secret the Sanity Function sends to the eve agent ───
EVE_TRIGGER_SECRET=
