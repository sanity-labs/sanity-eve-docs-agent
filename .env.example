# Copy to .env.local (eve loads it from the project root).

# ── Sanity project (read the article, stage the draft, link to Studio) ───────
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
SANITY_API_WRITE_TOKEN=         # project token, Editor role or above (reads + writes drafts)
SANITY_SCHEMA_ID=               # deployed schema id for Agent Actions, from `npx sanity schema list`
                                # (e.g. sanity.workspace.schema.default)
# "Review draft in Studio" button (optional). For a Sanity dashboard Studio, set the org id and
# app id — both are in your Studio's sanity.cli.ts (the app id is added on `sanity deploy`).
# The intent link is built as https://www.sanity.io/@<org>/studio/<appId>/<workspace>/intent/edit/...
SANITY_ORG_ID=                  # e.g. oSyH1iET5
SANITY_STUDIO_APP_ID=           # the studio app id from sanity.cli.ts
# SANITY_STUDIO_WORKSPACE=default   # set if your workspace isn't named "default"
# SANITY_STUDIO_URL=                # or override with an explicit base URL (e.g. a custom domain)

# ── Slack (the agent posts review-ready notices here) ────────────────────────
# Default: a Slack app provisioned by Vercel Connect (`vercel connect create slack`).
# Connect brokers the bot token at runtime, so there's no webhook or bot token to store.
SLACK_CONNECTOR=                # the Connect connector UID, e.g. slack/my-agent
SLACK_CHANNEL=                  # channel id to post to, e.g. C0123456789 (invite the app to it)
# For local development, set an incoming webhook here: `eve dev` has no Vercel OIDC for Connect,
# so the agent posts via the webhook when it's present. Leave blank in production.
SLACK_WEBHOOK_URL=

# ── eve orchestrator model (or run `npx eve link`) ───────────────────────────
AI_GATEWAY_API_KEY=

# ── Trigger auth: shared secret the Sanity Function sends to the eve agent ───
EVE_TRIGGER_SECRET=
