# Copy to .env.local (eve loads it from the project root).

# ── Sanity project (read the article, stage the draft, link to Studio) ───────
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
SANITY_API_WRITE_TOKEN=         # project token, Editor role or above (reads + writes drafts)
SANITY_STUDIO_URL=              # optional; your deployed Studio, e.g. https://my.sanity.studio
                                # used for the "Review draft in Studio" Slack button

# ── Slack (the agent posts review-ready notices here) ────────────────────────
# Default: a Slack app provisioned by Vercel Connect (`vercel connect create slack`).
# Connect brokers the bot token at runtime, so there's no webhook or bot token to store.
SLACK_CONNECTOR=                # the Connect connector UID, e.g. slack/my-agent
SLACK_CHANNEL=                  # channel id to post to, e.g. C0123456789 (invite the app to it)
# Local-dev fallback: an incoming webhook works in `eve dev` without Connect/OIDC. If set,
# it takes precedence over Connect. Leave blank in production.
SLACK_WEBHOOK_URL=

# ── eve orchestrator model (or run `npx eve link`) ───────────────────────────
AI_GATEWAY_API_KEY=

# ── Trigger auth: shared secret the Sanity Function sends to the eve agent ───
EVE_TRIGGER_SECRET=
